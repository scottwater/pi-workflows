{
  "name": "review-agents",
  "description": "Multi-agent code review using skeptical, guideline, test, and error-handling agents",
  "modelPolicy": "agent",
  "context": "fresh",
  "clarify": false,
  "agentScope": "both",
  "chain": [
    {
      "parallel": [
        {
          "agent": "skeptical-engineer",
          "task": "Review the requested scope skeptically.\n\nScope/request:\n{{args}}\n\nFocus on hidden assumptions, design risks, correctness issues, maintainability, and likely regressions. Return high-confidence findings only."
        },
        {
          "agent": "code-reviewer",
          "task": "Review the requested scope for guideline compliance, correctness, regressions, and high-confidence implementation issues.\n\nScope/request:\n{{args}}"
        },
        {
          "agent": "pr-test-analyzer",
          "task": "Review the requested scope for missing tests, weak assertions, brittle test design, and coverage gaps.\n\nScope/request:\n{{args}}"
        },
        {
          "agent": "silent-failure-hunter",
          "task": "Review the requested scope for swallowed errors, weak fallbacks, silent failures, weak observability, and poor error reporting.\n\nScope/request:\n{{args}}"
        }
      ],
      "failFast": false
    },
    {
      "agent": "review-synthesizer",
      "task": "Synthesize these parallel review outputs into one final review. Do not edit files; this is review-only.\n\nOriginal scope/request:\n{{args}}\n\nReviewer outputs:\n{{previous}}\n\nDeduplicate overlapping findings, drop low-confidence noise, preserve file paths and concrete reasoning, and prioritize by severity/actionability."
    }
  ]
}
